{
  "name": "cc-web",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @cc-web/shared && npm run build --workspace @cc-web/server && npm run build --workspace @cc-web/client",
    "dev": "npm-run-all --parallel dev:*",
    "dev:server": "npm run dev --workspace @cc-web/server",
    "dev:client": "npm run dev --workspace @cc-web/client",
    "test": "npm run test --workspace @cc-web/server"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3"
  }
}
