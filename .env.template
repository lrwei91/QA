# =============================================
# QA 项目环境变量配置模板
# =============================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入真实的配置值
# 3. .env 文件已加入 .gitignore，请勿提交到 Git
# =============================================

# ---------------------------------------------
# ZenTao (禅道) 配置
# ---------------------------------------------
# 禅道实例 URL
ZENTAO_URL=https://cd.baa360.cc:20088

# 禅道账号
ZENTAO_ACCOUNT=your_username

# 禅道密码
ZENTAO_PASSWORD=your_password

# ---------------------------------------------
# Figma 配置
# ---------------------------------------------
# Figma Personal Access Token
# 获取方式：https://figma.com → Settings → security → Personal access tokens
# 格式：figd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIGMA_ACCESS_TOKEN=

# ---------------------------------------------
# 其他配置（预留）
# ---------------------------------------------
# 调试模式
# DEBUG=true
